---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../lib/paths";
import { formatPostDate, getDisplayTags } from "../../lib/postMeta";

const posts = (await getCollection("posts"))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const tags = [...new Set(posts.flatMap((post) => getDisplayTags(post.data)))];
const featured = posts.filter((post) => post.data.featured).slice(0, 3);
const articleLikeSlugs = new Set(posts.filter((post) => post.data.kind === "writing").map((post) => post.slug));
const activityPosts = posts.filter((post) => !articleLikeSlugs.has(post.slug));
const articlePosts = posts.filter((post) => articleLikeSlugs.has(post.slug));
---

<BaseLayout title="Works | Portfolio" description="実績一覧です。">
  <section class="page-intro">
    <div>
      <p class="eyebrow">公開実績</p>
      <h1>実績一覧</h1>
      <p class="lead">インターン、研究室、個人開発で公開できる実績をまとめています。</p>
    </div>
  </section>

  <section class="catalog-tools">
    <div class="filter-row">
      <button class="filter-button active" data-filter="all" aria-pressed="true">すべて</button>
      {tags.map((tag) => (
        <button class="filter-button" data-filter={tag} aria-pressed="false">#{tag}</button>
      ))}
    </div>
  </section>

  <section class="catalog-layout">
    <div class="work-ledger">
      <section class="archive-group">
        <div class="group-head">
          <p class="eyebrow">参加したもの</p>
          <h2>やったこと</h2>
        </div>
        <div class="group-ledger" id="post-list">
        {activityPosts.map((post) => (
          <article class="ledger-row case-row" data-tags={JSON.stringify(getDisplayTags(post.data))} data-kind={post.data.kind}>
            <div class="ledger-row-main">
              <div class="meta-row">
                <time datetime={post.data.publishedAt.toISOString()}>
                  {formatPostDate(post.data)}
                </time>
              </div>
              <h2>
                <a href={withBase(`/posts/${post.slug}/`)}>{post.data.title}</a>
              </h2>
              <div class="tag-row">
                {getDisplayTags(post.data).map((tag) => (
                  <span class="pill neutral">{tag}</span>
                ))}
              </div>
            </div>
          </article>
        ))}
        </div>
      </section>
      <section class="archive-group">
        <div class="group-head">
          <p class="eyebrow">書いたもの</p>
          <h2>記事・ブログ</h2>
        </div>
        <div class="group-ledger">
        {articlePosts.map((post) => (
          <article class="ledger-row case-row article-row" data-tags={JSON.stringify(getDisplayTags(post.data))} data-kind={post.data.kind}>
            <div class="ledger-row-main">
              <div class="meta-row">
                <time datetime={post.data.publishedAt.toISOString()}>
                  {formatPostDate(post.data)}
                </time>
              </div>
              <h2>
                <a href={withBase(`/posts/${post.slug}/`)}>{post.data.title}</a>
              </h2>
              <div class="tag-row">
                {getDisplayTags(post.data).map((tag) => (
                  <span class="pill neutral">{tag}</span>
                ))}
              </div>
            </div>
          </article>
        ))}
        </div>
      </section>
    </div>
    <aside class="catalog-sidebar">
      <section class="sidebar-block">
        <p class="eyebrow">最近追加</p>
        <div class="note-stack">
          {featured.map((post) => (
            <a class="mini-note" href={withBase(`/posts/${post.slug}/`)} data-kind={post.data.kind}>
              <strong>{post.data.title}</strong>
              <span>{formatPostDate(post.data)}</span>
            </a>
          ))}
        </div>
      </section>
    </aside>
  </section>

  <script>
    const buttons = Array.from(
      document.querySelectorAll<HTMLButtonElement>(".filter-button")
    );
    const cards = Array.from(document.querySelectorAll<HTMLElement>(".case-row"));

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const filter = button.dataset.filter;
        buttons.forEach((item) => {
          item.classList.remove("active");
          item.setAttribute("aria-pressed", "false");
        });
        button.classList.add("active");
        button.setAttribute("aria-pressed", "true");

        cards.forEach((card) => {
          const rawTags = card.getAttribute("data-tags") || "[]";
          const tags = JSON.parse(rawTags) as string[];
          const visible = filter === "all" || tags.includes(filter || "");
          card.toggleAttribute("hidden", !visible);
        });
      });
    });
  </script>

  <style>
    .catalog-tools,
    .catalog-layout,
    .catalog-sidebar,
    .note-stack,
    .archive-group,
    .group-ledger {
      display: grid;
      gap: 16px;
    }

    .catalog-tools {
      gap: 10px;
      padding: 14px 16px 12px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.46), rgba(255, 255, 255, 0.24));
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }

    .catalog-layout {
      grid-template-columns: minmax(0, 1fr) 240px;
      align-items: start;
      gap: 22px;
    }

    .archive-group {
      gap: 12px;
    }

    .group-head {
      display: grid;
      gap: 4px;
      padding-bottom: 6px;
      border-bottom: 1px solid var(--line);
    }

    .catalog-sidebar {
      position: sticky;
      top: 24px;
    }

    .sidebar-block,
    .mini-note {
      display: grid;
      gap: 6px;
    }

    .sidebar-block {
      gap: 10px;
    }

    .note-stack {
      padding-top: 8px;
    }

    .mini-note {
      --tape-bg: var(--tape-intern-bg);
      --tape-border: var(--tape-intern-border);
      position: relative;
      padding: 22px 0 10px;
      border-bottom: 1px solid var(--line);
      transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
    }

    .mini-note::before {
      content: "";
      position: absolute;
      top: 8px;
      left: 6px;
      width: 36px;
      height: 11px;
      background: var(--tape-bg);
      border: 1px solid var(--tape-border);
      transform: rotate(-4deg);
    }

    .mini-note:nth-child(2n) {
      transform: rotate(-0.7deg);
    }

    .mini-note:nth-child(3n) {
      transform: rotate(0.7deg);
    }

    .mini-note span {
      color: var(--muted);
      font-size: 0.8rem;
    }

    .mini-note:hover {
      transform: translateX(2px) rotate(0deg);
    }

    .case-row {
      --pin-color: var(--tape-intern-bg);
      --pin-ring: var(--tape-intern-border);
      position: relative;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0.84));
      padding-top: 26px;
      transform-origin: center 18px;
    }

    .article-row {
      position: relative;
    }

    .case-row::before,
    .case-row::after {
      content: "";
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }

    .case-row::before {
      top: 8px;
      width: 14px;
      height: 14px;
      border-radius: 999px;
      background:
        radial-gradient(circle at 35% 30%, rgba(255, 255, 255, 0.9), transparent 34%),
        var(--pin-color);
      border: 1px solid var(--pin-ring);
      box-shadow:
        0 2px 0 0 rgba(255, 255, 255, 0.55) inset,
        0 3px 8px var(--pin-metal-shadow);
      z-index: 2;
    }

    .case-row::after {
      top: 18px;
      width: 18px;
      height: 8px;
      border-radius: 999px;
      background:
        radial-gradient(circle at center, var(--pin-hole) 0 28%, transparent 72%);
      opacity: 0.9;
    }

    .case-row:nth-child(2n) {
      transform: rotate(-0.25deg);
    }

    .case-row:nth-child(3n) {
      transform: rotate(0.25deg);
    }

    .mini-note[data-kind="intern"] {
      --tape-bg: var(--tape-intern-bg);
      --tape-border: var(--tape-intern-border);
    }

    .case-row[data-kind="intern"] {
      --pin-color: var(--tape-intern-bg);
      --pin-ring: var(--tape-intern-border);
    }

    .mini-note[data-kind="lab"] {
      --tape-bg: var(--tape-lab-bg);
      --tape-border: var(--tape-lab-border);
    }

    .case-row[data-kind="lab"] {
      --pin-color: var(--tape-lab-bg);
      --pin-ring: var(--tape-lab-border);
    }

    .mini-note[data-kind="project"] {
      --tape-bg: var(--tape-project-bg);
      --tape-border: var(--tape-project-border);
    }

    .case-row[data-kind="project"] {
      --pin-color: var(--tape-project-bg);
      --pin-ring: var(--tape-project-border);
    }

    .mini-note[data-kind="writing"] {
      --tape-bg: var(--tape-writing-bg);
      --tape-border: var(--tape-writing-border);
    }

    .case-row[data-kind="writing"] {
      --pin-color: var(--tape-writing-bg);
      --pin-ring: var(--tape-writing-border);
    }

    @media (max-width: 820px) {
      .catalog-layout {
        grid-template-columns: 1fr;
      }

      .catalog-sidebar {
        position: static;
      }

      .mini-note:nth-child(2n),
      .mini-note:nth-child(3n) {
        transform: none;
      }

      .case-row:nth-child(2n),
      .case-row:nth-child(3n) {
        transform: none;
      }

    }
  </style>
</BaseLayout>
