---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../lib/paths";
import { formatPostDate, getDisplayTagPath, getDisplayTags } from "../../lib/postMeta";

export async function getStaticPaths() {
  const posts = await getCollection("posts");

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | Portfolio`} description={post.data.summary}>
  <article class="article-shell">
    <a class="text-link" href={withBase("/posts/")}>← 実績一覧へ戻る</a>
    <header class="article-header article-hero">
      <div class="hero-meta">
        <p class="eyebrow">Article</p>
        <time datetime={post.data.publishedAt.toISOString()}>
          {formatPostDate(post.data)}
        </time>
      </div>
      <h1>{post.data.title}</h1>
      <div class="tag-row">
        {getDisplayTags(post.data).map((tag) => (
          <a class="pill neutral tag-chip" href={withBase(getDisplayTagPath(tag))}>{tag}</a>
        ))}
      </div>
      {post.data.sourceUrl && (
        <a class="button ghost" href={post.data.sourceUrl} target="_blank" rel="noreferrer">記事リンクを見る</a>
      )}
    </header>

    <section class="prose">
      <Content />
    </section>
  </article>

  <style>
    .article-hero {
      gap: 14px;
      padding: 18px 18px 16px;
      border: 1px solid var(--line);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(247, 251, 255, 0.88));
      box-shadow: var(--shadow);
    }

    .article-hero h1 {
      max-width: 18ch;
      font-size: clamp(1.8rem, 5vw, 3.6rem);
      line-height: 1.05;
      letter-spacing: -0.04em;
      text-wrap: balance;
    }

    .hero-meta {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      color: var(--muted);
      font-size: 0.82rem;
    }

    .tag-chip {
      transition: transform 180ms ease, border-color 180ms ease, background-color 180ms ease;
    }

    .tag-chip:hover {
      transform: translateY(-1px);
      border-color: rgba(37, 99, 235, 0.24);
      background: rgba(37, 99, 235, 0.08);
    }

    .article-hero .button {
      width: fit-content;
      margin-top: 4px;
    }

    @media (max-width: 640px) {
      .article-hero h1 {
        font-size: clamp(1.6rem, 10vw, 2.4rem);
      }
    }
  </style>
</BaseLayout>
